# Django Secret Key (Generate a new one for production!)
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production

# Database Configuration (PostgreSQL on AWS RDS)
# Note: Fill these in with your actual AWS RDS credentials to use the database
# For local development without AWS RDS, you can use SQLite (see settings.py modification)
AWS_DB_NAME=your_db_name
AWS_DB_MASTER_USER=your_db_username
AWS_DB_PASSWORD=your_db_password
AWS_URI=your_rds_endpoint.amazonaws.com

# AWS Credentials for Amazon Rekognition (Flower Image Classification)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-2

# Google Earth Engine Project ID (for NDVI satellite data calculations)
# Follow: https://developers.google.com/earth-engine/guides/python_install#authentication
GEE_PROJECT_ID=your_google_earth_engine_project_id
